[Unit]
Description=Gunicorn service for FJAR wallet
After=network.target

[Service]
User=root
Group=www-data
WorkingDirectory=/root/fjar_wallet
EnvironmentFile=/etc/default/fjar_wallet
ExecStart=/root/fjar_wallet/.venv/bin/gunicorn \
    --workers 1 \
    --bind 0.0.0.0:8080 \
    config.wsgi:application
Restart=always
RestartSec=3

[Install]
WantedBy=multi-user.target
